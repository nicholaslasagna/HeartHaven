NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key

# Optional, but recommended for Cloudflare magic links and password reset redirects.
NEXT_PUBLIC_SITE_URL=https://your-hearthaven-domain.com

# Legacy fallback is still supported through the end of 2026.
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ------------------------------------------------------------------------
# Permanent ban system (migration 0023). All three are REQUIRED for the
# /api/internal/send-ban-email route. The route 500s gracefully if any is
# missing, so a partial config doesn't break the rest of the app.
# ------------------------------------------------------------------------

# Service-role key for the Supabase project. Used ONLY by the ban-email
# route to read permanent_bans + stamp email_sent_at. NEVER expose to the
# browser. Keep this out of any NEXT_PUBLIC_* variable.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Resend API key for outbound ban notification emails.
# Get one at https://resend.com → API Keys. Verify your sending domain
# (e.g. realfiction.store) first so the from-address below works.
RESEND_API_KEY=re_...

# Optional override for the From address. Defaults to
# "HeartHaven Safety <safety@realfiction.store>" when unset.
# RESEND_FROM_ADDRESS=HeartHaven Safety <safety@realfiction.store>

# Shared secret the admin uses when curl-ing /api/internal/send-ban-email.
# Generate with `openssl rand -base64 48` or similar. Rotate periodically.
INTERNAL_WEBHOOK_SECRET=replace-with-a-long-random-string
